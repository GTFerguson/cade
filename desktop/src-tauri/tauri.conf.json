{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "CADE",
  "version": "0.1.0",
  "identifier": "com.cade.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "python ../scripts/build-backend-sidecar.py",
    "frontendDist": "../../frontend/dist"
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico",
        "icons/icon.png"
      ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "resources": ["resources/*"],
    "externalBin": ["resources/cade-backend"]
  },
  "app": {
    "windows": [
      {
        "title": "CADE",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-window-capability",
          "description": "Permissions for the main window",
          "windows": ["main"],
          "permissions": [
            "core:window:allow-start-dragging",
            "core:window:allow-minimize",
            "core:window:allow-maximize",
            "core:window:allow-unmaximize",
            "core:window:allow-toggle-maximize",
            "core:window:allow-close",
            "dialog:allow-open",
            "dialog:default"
          ]
        }
      ]
    }
  }
}
