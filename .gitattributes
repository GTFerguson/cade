# Ensure shell scripts always use LF line endings (even on Windows)
*.sh text eol=lf

# Ensure batch files use CRLF on Windows
*.bat text eol=crlf

# Standard text files
*.md text
*.json text
*.toml text
*.yaml text
*.yml text

# Source code
*.py text
*.js text
*.ts text
*.tsx text
*.rs text
*.css text
*.html text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
