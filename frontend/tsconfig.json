{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,

    "baseUrl": ".",
    "paths": {
      "@core/*": ["../core/frontend/*"],
      "vitest": ["./node_modules/vitest"],
      "@tauri-apps/*": ["./node_modules/@tauri-apps/*"],
      "mertex.md": ["./node_modules/mertex.md"],
      "marked": ["./node_modules/marked"],
      "highlight.js": ["./node_modules/highlight.js"],
      "katex": ["./node_modules/@types/katex", "./node_modules/katex"],
      "katex/contrib/*": ["./node_modules/@types/katex/contrib/*", "./node_modules/katex/contrib/*"],
      "katex/*": ["./node_modules/katex/*"],
      "mermaid": ["./node_modules/mermaid"]
    }
  },
  "include": ["src", "../core/frontend"]
}
